<UserControl x:Class="CSVC_PTIT.App.Views.SV.TraCuuCSVCView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadDataCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Grid.Row="0"
                   Text="Tra cứu CSVC khả dụng"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,16" />

        <!-- Bộ lọc -->
        <md:Card Grid.Row="1" Padding="16" Margin="0,0,0,12"
                 md:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Margin="0,0,12,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         md:HintAssist.Hint="Tìm theo mã hoặc tên CSVC..."
                         md:TextFieldAssist.HasClearButton="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                <ComboBox Grid.Column="1"
                          Margin="0,0,12,0"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          DisplayMemberPath="Name"
                          md:HintAssist.Hint="Loại CSVC"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                <DatePicker Grid.Column="2"
                            Margin="0,0,12,0"
                            SelectedDate="{Binding SelectedDate}"
                            md:HintAssist.Hint="Ngày mượn"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />

                <Button Grid.Column="3"
                        Command="{Binding ClearFilterCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        ToolTip="Xóa bộ lọc">
                    <md:PackIcon Kind="FilterRemove" />
                </Button>
            </Grid>
        </md:Card>

        <!-- Tóm tắt + Làm mới -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding ResultSummary}"
                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MaterialDesignBodyLight}" />

            <Button Grid.Column="1"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    ToolTip="Làm mới">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="Refresh" Margin="0,0,4,0" />
                    <TextBlock Text="Làm mới" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- DataGrid kết quả -->
        <md:Card Grid.Row="3" md:ElevationAssist.Elevation="Dp2">
            <Grid>
                <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}"
                             IsIndeterminate="True"
                             Visibility="{Binding IsLoading,
                                          Converter={StaticResource BooleanToVisibilityConverter}}"
                             VerticalAlignment="Top" />

                <DataGrid ItemsSource="{Binding Assets}"
                          SelectedItem="{Binding SelectedAsset}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          Margin="0,4,0,0">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã CSVC"
                                            Binding="{Binding AssetCode}"
                                            />
                        <DataGridTextColumn Header="Tên CSVC"
                                            Binding="{Binding AssetName}"
                                            Width="*" />
                        <DataGridTextColumn Header="Loại"
                                            Binding="{Binding Category.Name}"
                                            />
                        <DataGridTextColumn Header="SL khả dụng"
                                            Binding="{Binding AvailableQuantity}"
                                            >
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="Medium" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AvailableQuantity}" Value="0">
                                            <Setter Property="Foreground" Value="OrangeRed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="SL tổng"
                                            Binding="{Binding TotalQuantity}"
                                            >
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Vị trí"
                                            Binding="{Binding Location}"
                                            />
                        <DataGridTemplateColumn Header="Trạng thái" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,2"
                                            Background="#4CAF50"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="Khả dụng"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   FontWeight="Medium" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </md:Card>

        <!-- Lỗi -->
        <TextBlock Grid.Row="4"
                   Text="{Binding ErrorMessage}"
                   Foreground="OrangeRed"
                   Margin="0,8,0,0" />
    </Grid>
</UserControl>
