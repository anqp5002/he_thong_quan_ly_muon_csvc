<Window x:Class="CSVC_PTIT.App.Views.SV.YeuCauHoanTraView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Yêu Cầu Hoàn Trả CSVC" Height="600" Width="900">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Grid.Row="0" Text="Yêu Cầu Hoàn Trả CSVC"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,16"/>

        <!-- Nút tải -->
        <Button Grid.Row="1" Content="Tải danh sách đang mượn"
                Command="{Binding TaiDanhSachCommand}"
                Style="{StaticResource MaterialDesignRaisedButton}"
                HorizontalAlignment="Left"
                Margin="0,0,0,16"/>

        <!-- Danh sách đơn đang mượn -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding DanhSachDangMuon}"
                  SelectedItem="{Binding DonDuocChon}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  materialDesign:DataGridAssist.CellPadding="8"
                  Margin="0,0,0,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã đơn" Binding="{Binding RequestCode}" Width="100"/>
                <DataGridTextColumn Header="Tiêu đề" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Giờ bắt đầu" Binding="{Binding BorrowStartAt, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                <DataGridTextColumn Header="Giờ phải trả" Binding="{Binding ExpectedReturnAt, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Ghi chú tình trạng -->
        <TextBox Grid.Row="3"
                 Text="{Binding GhiChuTinhTrang, UpdateSourceTrigger=PropertyChanged}"
                 materialDesign:HintAssist.Hint="Ghi chú tình trạng CSVC khi trả"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 AcceptsReturn="True" Height="80"
                 Margin="0,0,0,16"/>

        <!-- Thông báo + Nút gửi -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="{Binding ThongBao}" Foreground="Green"
                       Margin="0,0,0,8" FontWeight="Bold"/>

            <Button Content="Gửi yêu cầu hoàn trả"
                    Command="{Binding GuiYeuCauTraCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    HorizontalAlignment="Right"/>
        </StackPanel>

    </Grid>
</Window>