<UserControl x:Class="CSVC_PTIT.App.Views.QL.BanGiaoCSVCView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Background="White">
        <StackPanel Margin="20">
            <TextBlock Text="Bàn Giao Cơ Sở Vật Chất (Dev C - Sprint 1)" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <TextBlock Text="Danh sách các đơn đã duyệt chờ bàn giao:" FontSize="16" Margin="0,0,0,10"/>
            
            <DataGrid x:Name="GridDonMuon" AutoGenerateColumns="False" CanUserAddRows="False" 
                      Height="200" Margin="0,0,0,20">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã Đơn" Binding="{Binding RequestCode}" Width="100"/>
                    <DataGridTextColumn Header="Người Mượn" Binding="{Binding Requester.FullName}" Width="200"/>
                    <DataGridTextColumn Header="Ngày Mượn" Binding="{Binding BorrowStartAt, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="150"/>
                    <DataGridTextColumn Header="Trạng Thái" Binding="{Binding Status}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="BtnCreateCheckout" Content="Tạo Phiếu Bàn Giao" 
                        Click="BtnCreateCheckout_Click" Margin="0,0,10,0"/>
                <Button x:Name="BtnExportPdf" Content="Xuất PDF Biên Bản (Demo Sprint 3)" 
                        Click="BtnExportPdf_Click" 
                        Style="{StaticResource MaterialDesignOutlinedButton}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
