<UserControl x:Class="CSVC_PTIT.App.Views.DanhMucCSVCView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <materialDesign:Card Grid.Row="0" Margin="0,0,0,16" Padding="16" UniformCornerRadius="8">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="BtnAdd_Click" Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center"/>
                        <TextBlock Text=" THÊM CSVC" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <ComboBox DockPanel.Dock="Right"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          DisplayMemberPath="CategoryName"
                          materialDesign:HintAssist.Hint="Lọc loại"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Width="180" Margin="8,0,0,0"
                          materialDesign:TextFieldAssist.HasClearButton="True"/>

                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Tìm theo mã, tên CSVC..."
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         VerticalAlignment="Center"/>
            </DockPanel>
        </materialDesign:Card>

        <!-- Loading -->
        <ProgressBar Grid.Row="1"
                     Style="{StaticResource MaterialDesignCircularProgressBar}"
                     IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                     VerticalAlignment="Top" Margin="0,16,0,0"/>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Assets}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  materialDesign:DataGridAssist.CornerRadius="8"
                  materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                  HeadersVisibility="Column">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã CSVC" Binding="{Binding AssetCode}" Width="100"/>
                <DataGridTextColumn Header="Tên" Binding="{Binding AssetName}" Width="*"/>
                <DataGridTextColumn Header="Loại" Binding="{Binding Category.CategoryName}" Width="140"/>

                <!-- Tình trạng có màu -->
                <DataGridTemplateColumn Header="Tình trạng" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <materialDesign:Chip>
                                <materialDesign:Chip.Style>
                                    <Style TargetType="materialDesign:Chip" BasedOn="{StaticResource {x:Type materialDesign:Chip}}">
                                        <Setter Property="Content" Value="Tốt"/>
                                        <Setter Property="Background" Value="#E8F5E9"/>
                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ConditionStatus}" Value="Fair">
                                                <Setter Property="Content" Value="Khá"/>
                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                <Setter Property="Foreground" Value="#E65100"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ConditionStatus}" Value="Damaged">
                                                <Setter Property="Content" Value="Hỏng"/>
                                                <Setter Property="Background" Value="#FFEBEE"/>
                                                <Setter Property="Foreground" Value="#C62828"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:Chip.Style>
                            </materialDesign:Chip>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="SL tổng" Binding="{Binding TotalQuantity}" Width="80"/>
                <DataGridTextColumn Header="SL khả dụng" Binding="{Binding AvailableQuantity}" Width="100"/>

                <!-- Hành động -->
                <DataGridTemplateColumn Header="Hành động" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Sửa" Click="BtnEdit_Click" Tag="{Binding}">
                                    <materialDesign:PackIcon Kind="Pencil" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Xóa" Click="BtnDelete_Click" Tag="{Binding}">
                                    <materialDesign:PackIcon Kind="Delete" Foreground="#F44336"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
