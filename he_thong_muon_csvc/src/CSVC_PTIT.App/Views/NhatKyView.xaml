<UserControl x:Class="CSVC_PTIT.App.Views.NhatKyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filter bar -->
        <materialDesign:Card Grid.Row="0" Margin="0,0,0,16" Padding="16" UniformCornerRadius="8">
            <StackPanel Orientation="Horizontal">
                <DatePicker SelectedDate="{Binding FromDate}"
                            materialDesign:HintAssist.Hint="Từ ngày"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Width="150" Margin="0,0,8,0"/>

                <DatePicker SelectedDate="{Binding ToDate}"
                            materialDesign:HintAssist.Hint="Đến ngày"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Width="150" Margin="0,0,8,0"/>

                <ComboBox materialDesign:HintAssist.Hint="Loại hành động"
                          Text="{Binding FilterAction}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          IsEditable="True" Width="160" Margin="0,0,8,0"
                          materialDesign:TextFieldAssist.HasClearButton="True">
                    <ComboBoxItem Content=""/>
                    <ComboBoxItem Content="Thêm"/>
                    <ComboBoxItem Content="Sửa"/>
                    <ComboBoxItem Content="Xóa"/>
                    <ComboBoxItem Content="Đăng nhập"/>
                    <ComboBoxItem Content="Khóa"/>
                    <ComboBoxItem Content="Duyệt"/>
                </ComboBox>

                <Button Content="TÌM KIẾM"
                        Command="{Binding LoadDataCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Magnify" VerticalAlignment="Center"/>
                                <TextBlock Text=" TÌM KIẾM" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>
        </materialDesign:Card>

        <!-- Loading -->
        <ProgressBar Grid.Row="1"
                     Style="{StaticResource MaterialDesignCircularProgressBar}"
                     IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                     VerticalAlignment="Top" Margin="0,16,0,0"/>

        <!-- DataGrid nhật ký -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Logs}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  materialDesign:DataGridAssist.CornerRadius="8"
                  materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                  HeadersVisibility="Column">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Thời điểm" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="160"/>
                <DataGridTextColumn Header="Người thực hiện" Binding="{Binding User.FullName}" Width="160"/>
                <DataGridTextColumn Header="Loại" Binding="{Binding Action}" Width="100"/>
                <DataGridTextColumn Header="Đối tượng" Binding="{Binding TargetType}" Width="120"/>
                <DataGridTextColumn Header="Chi tiết" Binding="{Binding Detail}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
