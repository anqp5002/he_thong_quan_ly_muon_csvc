<Window x:Class="CSVC_PTIT.App.Views.DT.ThongBaoKetQuaDuyetView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Thông Báo Kết Quả Duyệt" Height="600" Width="900">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Grid.Row="0" Text="Thông Báo Kết Quả Duyệt Đơn"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,16"/>

        <!-- Nút tải -->
        <Button Grid.Row="1" Content="Tải thông báo"
                Command="{Binding TaiThongBaoCommand}"
                Style="{StaticResource MaterialDesignRaisedButton}"
                HorizontalAlignment="Left"
                Margin="0,0,0,16"/>

        <!-- Danh sách thông báo -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding DanhSachThongBao}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  materialDesign:DataGridAssist.CellPadding="8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã đơn" Binding="{Binding RequestCode}" Width="100"/>
                <DataGridTextColumn Header="Tên sự kiện" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Kết quả" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Thời gian duyệt" Binding="{Binding ApprovedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                <DataGridTextColumn Header="Lý do từ chối" Binding="{Binding RejectReason}" Width="*"/>
            </DataGrid.Columns>

            <!-- Màu sắc theo trạng thái -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="Approved">
                            <Setter Property="Foreground" Value="Green"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="Rejected">
                            <Setter Property="Foreground" Value="Red"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

    </Grid>
</Window>