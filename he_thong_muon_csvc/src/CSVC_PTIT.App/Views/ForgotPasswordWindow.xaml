<Window x:Class="CSVC_PTIT.App.Views.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Quên mật khẩu" Height="400" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="Khôi phục mật khẩu" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,16" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
            
            <TextBlock x:Name="TxtMessage" Foreground="Green" TextWrapping="Wrap" Margin="0,0,0,16" HorizontalAlignment="Center" Visibility="Collapsed" />
            <TextBlock x:Name="TxtError" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,16" HorizontalAlignment="Center" Visibility="Collapsed" />

            <TextBox x:Name="TxtEmail" materialDesign:HintAssist.Hint="Nhập Email của bạn" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16" />

            <Button x:Name="BtnSendOtp" Content="Gửi mã OTP" Click="BtnSendOtp_Click" Margin="0,0,0,16" />

            <StackPanel x:Name="PanelReset" Visibility="Collapsed">
                <TextBox x:Name="TxtOtp" materialDesign:HintAssist.Hint="Nhập mã OTP (6 số)" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,16" />
                <PasswordBox x:Name="TxtNewPassword" materialDesign:HintAssist.Hint="Mật khẩu mới" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" Margin="0,0,0,16" />
                
                <Button x:Name="BtnResetPassword" Content="ĐẶT LẠI MẬT KHẨU" Click="BtnResetPassword_Click" Margin="0,8,0,0" />
            </StackPanel>
            
            <ProgressBar x:Name="ProgressBusy" Style="{StaticResource MaterialDesignCircularProgressBar}" Value="0" IsIndeterminate="True" Margin="0,16,0,0" Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</Window>
