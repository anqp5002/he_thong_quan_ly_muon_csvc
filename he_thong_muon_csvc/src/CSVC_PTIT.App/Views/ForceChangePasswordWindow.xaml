<Window x:Class="CSVC_PTIT.App.Views.ForceChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Đổi mật khẩu lần đầu" Height="300" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="Đổi mật khẩu lần đầu" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
            
            <TextBlock Text="Vì lý do bảo mật, bạn bắt buộc phải đổi mật khẩu mặc định trước khi sử dụng hệ thống." TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,16" TextAlignment="Center" />
            
            <TextBlock x:Name="TxtError" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,16" HorizontalAlignment="Center" Visibility="Collapsed" />

            <PasswordBox x:Name="TxtNewPassword" materialDesign:HintAssist.Hint="Mật khẩu mới" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" Margin="0,0,0,16" />
            
            <PasswordBox x:Name="TxtConfirmPassword" materialDesign:HintAssist.Hint="Xác nhận mật khẩu mới" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" Margin="0,0,0,24" />

            <Button x:Name="BtnChange" Content="LƯU MẬT KHẨU" Click="BtnChange_Click" />
            
            <ProgressBar x:Name="ProgressBusy" Style="{StaticResource MaterialDesignCircularProgressBar}" Value="0" IsIndeterminate="True" Margin="0,16,0,0" Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</Window>
