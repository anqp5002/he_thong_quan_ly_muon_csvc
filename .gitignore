## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ins.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# NuGet Packages
*.nupkg
packages/
project.lock.json

# Docker
docker-compose.override.yml
.dockerignore

# Design & Requirements Documents (ignored as requested)
*.doc
*.docx
*.xlsx
*.drawio
